rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Support Tickets Collection
    match /contacts/{ticketId} {
      // Anyone can submit a support ticket from the contact page
      allow create: if true;
      
      // Allow single document retrieval (so anonymous ticket tracking works if they know the ID)
      allow get: if true;

      // Restrict collection listing and querying to admins or the ticket owner
      allow list: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.email == 'thefifthagefilms@gmail.com' ||
        request.auth.token.email == 'rahulchakradharperepogu@gmail.com' ||
        resource.data.userId == request.auth.uid
      );
      
      // Restrict editing and deleting strictly to authenticated admins
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'thefifthagefilms@gmail.com' ||
        request.auth.token.email == 'rahulchakradharperepogu@gmail.com'
      );
    }
    
    // Rate Limiting (Admin-only read/write)
    match /rate_limits/{limitId} {
      allow read, write: if false; // Only accessible via Firebase Admin SDK
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
